# --- Gemini ---
GEMINI_API_KEY=your_gemini_key_here    # optional: an admin can also set this on /admin
FILE_SEARCH_STORE=            # filled in by index_document.py
GEMINI_MODEL=gemini-2.5-flash

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_TOKEN=your_meta_access_token
PHONE_NUMBER_ID=your_whatsapp_phone_number_id
VERIFY_TOKEN=pick_any_random_string
APP_SECRET=your_meta_app_secret        # for webhook signature verification (recommended)
GRAPH_VERSION=v21.0

# --- Redis / behaviour ---
REDIS_URL=redis://localhost:6379
MAX_HISTORY_TURNS=6
HISTORY_TTL_SEC=86400
RATE_LIMIT_PER_MIN=12
